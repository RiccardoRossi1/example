
/* Global Styles */
body {
    margin: 0;
    padding: 0;
    font-family: Arial, sans-serif;
    background-color: #F2EFEA;
    color: #4C3957;
}

h1, h2, h3, h4, h5, h6 {
    color: #414073;
}

p {
    line-height: 1.6;
}

a {
    color: #23A25C;
    text-decoration: none;
}

a:hover {
    text-decoration: underline;
}

/* Navbar styles */
.navbar {
    background-color: #414073;
    position: sticky;
    top: 0;
    width: 100%;
    z-index: 1000;
    margin: 0;
    padding: 10px 20px; /* Adds breathing room */
    box-shadow: 0 2px 6px rgba(0, 0, 0, 0.1); /* Optional: subtle depth */
}

.navbar-list {
    display: flex;
    justify-content: center;
    align-items: center;
    list-style: none;
    margin: 0;
    padding: 0;
    gap: 16px; 
    flex-wrap: nowrap;
}

.Navbar-list li {
    list-style: none;
}

.navbar-list li a {
    display: inline-block;
    padding: 10px 20px;
    min-width: 120px; 
    text-align: center;
    color: white;
    font-weight: 500;
    border-radius: 6px;
    text-decoration: none;
    transition: background-color 0.3s ease, transform 0.2s ease;
    white-space: nowrap;
}

.navbar-list li a:hover {
    background-color: #0B6E4F;
    transform: scale(1.05); 
}

.navbar-list li a.active {
    background-color: #23A25C;
}

/* Form Styles */
form {
    background-color: #F2EFEA;
    color: #0B6E4F;
    padding: 20px;
    border-radius: 10px;
    max-width: 500px;
    margin: auto;
}

label {
    display: block;
    margin-top: 15px;
    font-weight: bold;
    color: #0B6E4F;
}

input, textarea, select {
    width: 100%;
    padding: 8px;
    margin-top: 5px;
    border: 1px solid #4C3957;
    border-radius: 5px;
}

/* Button Styles */
.button,
input[type="submit"],
button,
.login-signup-buttons a,
.cta-section a,
.hero-section .btn-primary,
.hero-section .btn-secondary,
.feature-link {
  display: inline-block;
  font-size: 16px;
  font-weight: 600;
  padding: 12px 24px;
  background-color: #23A25C;
  color: white;
  border: none;
  border-radius: 6px;
  text-align: center;
  text-decoration: none;
  box-sizing: border-box;
  min-width: 150px;
  max-width: 100%;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
  transition: background-color 0.3s ease, transform 0.2s ease;
}



.button:hover,
input[type="submit"]:hover,
button:hover,
.login-signup-buttons a:hover,
.cta-section a:hover,
.hero-section .btn-primary:hover,
.hero-section .btn-secondary:hover,
.feature-link:hover {
  background-color: #0B6E4F;
  transform: scale(1.05);
  box-shadow: 0 6px 14px rgba(0, 0, 0, 0.3);
}


/* Login/Signup Container Styles */
.signup-container,
.login-container {
    background-color: #F2EFEA;
    color: #0B6E4F;
    padding: 20px;
    border-radius: 10px;
    max-width: 500px;
    margin: 80px auto;
    box-shadow: 0 0 10px rgba(0, 0, 0, 0.1);
}

.signup-container h2,
.login-container h2 {
    text-align: center;
}

/* Form Button Styles */
form button {
    display: block;
    margin: 20px auto 0;
    width: 150px;
    height: 40px;
}

/* Hero Section Styles */
.hero-section {
    background-image: url('images/hero-bg.jpg');
    background-size: cover;
    background-position: center;
    color: #414073;
    padding: 80px 20px;
    text-align: center;
}

.hero-section h2 {
    margin-bottom: 20px;
}

.hero-section p {
    font-size: 18px;
}

.hero-section .btn-primary,
.hero-section .btn-secondary {
    margin: 10px;
    padding: 15px 30px;
    font-size: 16px;
    border-radius: 5px;
    text-decoration: none;
}

.hero-section .btn-primary {
    background-color: #0B6E4F;
}

.hero-section .btn-secondary {
    background-color: #414073;
}

.hero-section .btn-primary:hover,
.hero-section .btn-secondary:hover {
    background-color: #23A25C;
}

/* Features Section Styles */
.features-section {
    padding: 50px 20px;
    background-color: #E8E4DA;
    text-align: center;
}

.features-section h2 {
    color: #0B6E4F;
    margin-bottom: 30px;
}

.features-section .feature-container {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: 30px;
}

.feature {
    background-color: #fff;
    border-radius: 10px;
    padding: 20px;
    width: 250px;
    box-shadow: 0 2px 8px rgba(0,0,0,0.1);
    transition: transform 0.3s ease;
}

.feature:hover {
    transform: translateY(-5px);
}

.feature h3 {
    color: #414073;
    margin-bottom: 15px;
}

.feature p {
    font-size: 14px;
}

/* CTA Section Styles */
.cta-section {
  text-align: center;
  padding: 60px 20px;
  background-color: #414073;
  border-radius: 10px;
}


.cta-section h2 {
    margin-bottom: 20px;
}

/* Footer Styles */
.footer {
    background-color: #414073;
    color: white;
    text-align: center;
    padding: 15px 0;
    margin-top: 40px;
}

.footer p {
    margin: 0;
    font-size: 14px;
}

.footer-content {
    max-width: 800px;
    margin: 0 auto;
    padding: 0 20px;
}

/* Newsletter */
.container {
    max-width: 600px;
    margin: 0 auto;
    padding: 20px;
    background-color: #E8E4DA;
    border-radius: 10px;
    text-align: center;
    box-shadow: 0 2px 8px rgba(0,0,0,0.1);
    padding-bottom: 60px;
}

.newsletter-container {
    max-width: 600px;
    margin: 0 auto;
    padding: 20px;
    background-color: #F2EFEA;
    border-radius: 10px;
    text-align: center;
    box-shadow: 0 2px 8px rgba(0,0,0,0.1);
    padding-bottom: 60px;
}

.container h2 {
    color: #0B6E4F;
    margin-bottom: 15px;
}
.container input[type="email"] {
    width: 70%;
    padding: 10px;
    margin-right: 10px;
    border: 1px solid #4C3957;
    border-radius: 5px;
}
.container button {
    padding: 10px 20px;
    background-color: #23A25C;
    color: white;
    border: none;
    border-radius: 5px;
    cursor: pointer;
}
.container button:hover {
    background-color: #0B6E4F;
}

#newsletter-form {
    margin-top: 20px;
    background-color: #F2EFEA;
}


/* Fade-in Animation */
.fade-in {
    opacity: 0;
    transform: translateY(20px);
    transition: opacity 1s ease, transform 1s ease;
}

.fade-in.visible {
    opacity: 1;
    transform: translateY(0);
}

/* Animation Styles */
@keyframes fadeIn {
    to {
        opacity: 1;
    }
}

@media (max-width: 768px) {
    .navbar {
        flex-direction: column;
        align-items: center;
    }

    .feature {
        width: 100%;
    }

    .login-signup-buttons {
        flex-direction: column;
        align-items: center;
    }

    .hero-section {
        padding: 40px 10px;
    }

    .hero-section h2 {
        font-size: 24px;
    }

    .hero-section p {
        font-size: 16px;
    }

    .features-section .feature-container {
        flex-direction: column;
        align-items: center;
    }
}

/* General Section Spacing */
section {
    margin-bottom: 60px;
}

