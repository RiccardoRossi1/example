    background-color: #23A25C;
    color: white;
    border: none;
    border-radius: 8px;
    font-size: 18px;
    font-weight: 600;
    cursor: pointer;
    transition: background-color 0.3s ease, transform 0.2s ease;
}

.calculate-btn:hover {
    background-color: #0B6E4F;
    transform: scale(1.03);
}

/* Results */

